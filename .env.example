# Copy to .env for running the examples/tests against real sandbox keys.
# pay-kit itself never reads these - you pass secretKey to createPayClient().

# Paystack (https://dashboard.paystack.com/#/settings/developers)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# Flutterwave (https://app.flutterwave.com/dashboard/settings/apis)
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxx-X
# The "Secret hash" you set under Settings > Webhooks - used to verify webhooks.
FLUTTERWAVE_WEBHOOK_HASH=your-webhook-secret-hash

# --- Optional, for `bun run integration` ---
# A test account number + provider bank code to exercise resolveAccount (and,
# with RUN_TRANSFERS=1, a test-mode payout). Leave unset to skip those steps.
#
# Bank codes are provider-specific, so you can set them per provider. The
# generic RESOLVE_ACCOUNT / RESOLVE_BANK are used as a fallback for both.
#   Paystack test mode: use bank code 001 (live resolves are limited to 3/day).
#   Flutterwave test:    account 0690000040, bank 044 resolves to a test name.
# PAYSTACK_RESOLVE_ACCOUNT=0000000000
# PAYSTACK_RESOLVE_BANK=001
# FLUTTERWAVE_RESOLVE_ACCOUNT=0690000040
# FLUTTERWAVE_RESOLVE_BANK=044
# RUN_TRANSFERS=1

# Flutterwave transfers require IP whitelisting (Dashboard > Settings >
# Whitelisted IP addresses). Whitelist your current public IP (curl api.ipify.org).
