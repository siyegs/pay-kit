{
  "name": "@siyegs/pay-kit",
  "version": "0.8.1",
  "description": "One typed SDK for African payment rails - unified Paystack & Flutterwave: charge, verify, refund, transfer/payout, resolve accounts, list banks, and verify webhooks, with provider fallback and a keyless mock provider for tests.",
  "type": "module",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siyegs/pay-kit.git"
  },
  "homepage": "https://github.com/siyegs/pay-kit#readme",
  "bugs": {
    "url": "https://github.com/siyegs/pay-kit/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "integration": "bun run scripts/integration.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run test && bun run build"
  },
  "keywords": [
    "paystack",
    "flutterwave",
    "payments",
    "payment-gateway",
    "payouts",
    "transfers",
    "bank-resolution",
    "testing",
    "mock",
    "nigeria",
    "africa",
    "fintech",
    "typescript",
    "sdk",
    "webhooks"
  ],
  "author": "Iyegere Success Karboloo",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "tsup": "^8.1.0",
    "typescript": "^5.4.5"
  }
}
